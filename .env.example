# --- AI Studio / Cloud Run Environment Variables ---
# These are automatically injected by the platform at runtime.
GEMINI_API_KEY="your_gemini_api_key_here"
APP_URL="your_app_url_here"

# --- Firebase Configuration (Client-Side) ---
# These variables are required for the app to connect to Firebase.
# When deploying to Vercel or other platforms, add these to your environment settings.
# Prefix with VITE_ to expose them to the client-side code.

VITE_FIREBASE_API_KEY="your_api_key"
VITE_FIREBASE_AUTH_DOMAIN="your_project_id.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="your_project_id"
VITE_FIREBASE_STORAGE_BUCKET="your_project_id.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID="your_messaging_sender_id"
VITE_FIREBASE_APP_ID="your_app_id"
VITE_FIREBASE_MEASUREMENT_ID="your_measurement_id"
VITE_FIREBASE_FIRESTORE_DATABASE_ID="your_firestore_database_id"
