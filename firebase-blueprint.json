{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "username": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "username", "createdAt"]
    },
    "Message": {
      "title": "Message",
      "description": "A message sent in the chat",
      "type": "object",
      "properties": {
        "senderId": { "type": "string" },
        "senderUsername": { "type": "string" },
        "text": { "type": "string" },
        "fileUrl": { "type": "string" },
        "fileType": { "type": "string" },
        "fileName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["senderId", "senderUsername", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/usernames/{username}": {
      "schema": { "type": "object", "properties": { "uid": { "type": "string" } } },
      "description": "Unique username mapping"
    },
    "/messages/{messageId}": {
      "schema": "Message",
      "description": "Global chat messages"
    }
  }
}
