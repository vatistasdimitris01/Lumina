{
  "entities": {
    "Channel": {
      "title": "Channel",
      "description": "A chat channel or group.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The name of the channel." },
        "description": { "type": "string", "description": "A short description of the channel." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the channel was created." },
        "createdBy": { "type": "string", "description": "The UID of the user who created the channel." },
        "messageRetentionDays": { "type": "number", "description": "Retention period in days (30 or 60)." }
      },
      "required": ["name", "createdAt", "createdBy", "messageRetentionDays"]
    },
    "Message": {
      "title": "Message",
      "description": "A message within a channel.",
      "type": "object",
      "properties": {
        "senderId": { "type": "string", "description": "The UID of the sender." },
        "senderUsername": { "type": "string", "description": "The username of the sender." },
        "text": { "type": "string", "description": "The message text." },
        "fileUrl": { "type": "string", "description": "URL of the uploaded file." },
        "fileType": { "type": "string", "description": "MIME type of the file." },
        "fileName": { "type": "string", "description": "Name of the file." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the message was sent." }
      },
      "required": ["senderId", "senderUsername", "createdAt"]
    },
    "Member": {
      "title": "Member",
      "description": "A user who is a member of a channel.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The UID of the user." },
        "joinedAt": { "type": "string", "format": "date-time", "description": "When the user joined." }
      },
      "required": ["userId", "joinedAt"]
    },
    "Friend": {
      "title": "Friend",
      "description": "A friendship between two users.",
      "type": "object",
      "properties": {
        "userId1": { "type": "string", "description": "UID of the first user." },
        "userId2": { "type": "string", "description": "UID of the second user." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the friendship was created." }
      },
      "required": ["userId1", "userId2", "createdAt"]
    }
  },
  "firestore": {
    "/channels/{channelId}": {
      "schema": { "$ref": "Channel" },
      "description": "Stores channel information."
    },
    "/channels/{channelId}/messages/{messageId}": {
      "schema": { "$ref": "Message" },
      "description": "Stores messages within a channel."
    },
    "/channels/{channelId}/members/{userId}": {
      "schema": { "$ref": "Member" },
      "description": "Stores channel members."
    },
    "/friends/{friendId}": {
      "schema": { "$ref": "Friend" },
      "description": "Stores friendships."
    }
  }
}
